generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sugestao {
  id        Int      @id @default(autoincrement())
  nome      String
  sugestao  String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
}
